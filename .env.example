# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required for workspace / run operations (HCP Terraform or TFE token)
TFE_TOKEN=

# Optional: override for self-hosted Terraform Enterprise
# Defaults to https://app.terraform.io
TFE_ADDRESS=

# Optional: absolute path to the terraform-mcp-server binary.
# If not set, the binary is expected to be on PATH.
TERRAFORM_MCP_SERVER=
